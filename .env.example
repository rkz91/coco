# CoCo Platform Configuration
# Copy to .env and customize

# Edition: "core" (free, MIT) or "studio" (BSL 1.1, adds voice/AI features)
COCO_EDITION=core

# Data directories
COCO_DIR=~/.coco
HUB_DIR=~/.hub

# Database (default: SQLite, supports PostgreSQL)
# DATABASE_URL=sqlite:///~/.coco/platform.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/coco

# Server
PLATFORM_PORT=8000

# Agent limits
MAX_CONCURRENT_AGENTS=3
AGENT_TIMEOUT_MINUTES=30
CHAT_TIMEOUT_MINUTES=5

# API keys (Studio features)
# DEEPGRAM_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here

# Agent SDK (use Anthropic API instead of claude CLI)
USE_AGENT_SDK=false

# Security (optional — only set for non-local deployments)
# COCO_AUTH_TOKEN=your-secret-token
# COCO_CORS_ORIGINS=http://localhost:5173
